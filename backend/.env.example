# waliFit backend env — copy to .env and fill in real values
# .env is gitignored. Never commit real secrets.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ─── Supabase ────────────────────────────────────────────────────────────────
# From https://app.supabase.com → your project → Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...
SUPABASE_JWT_SECRET=

# ─── Database ────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (use pooled connection for prod)
# Format: postgresql://postgres.<project>:<password>@<host>:5432/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/walifit
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/walifit

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to hit the backend
CORS_ORIGINS=http://localhost:8081,http://localhost:19000,http://localhost:19006

# ─── AI providers (Phase 6 — Wali AI) ─────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=

# ─── Redis / queues (Phase 4+ — BullMQ) ──────────────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
