// waliFit backend — Prisma schema
// Aligns with Supabase auth.users via User.id (UUID matches Supabase user UUID).
// V1 core models: User, VitalityState, WorkoutLog, WorkoutSet, DailyScore,
// SimpleNutritionLog, PRRecord, UserMemory (empty), Badge, UserBadge.
// Run data lives on WorkoutLog (no separate model — per V1 features doc §F12).
// Spec source of truth: docs/waliFit_Technical_Architecture.md §3, §14.2, §15.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UnitSystem {
  metric
  imperial
}

enum WorkoutType {
  strength
  hybrid
  conditioning
  run
  rest
}

enum RunType {
  free
  preset
}

enum RunDistancePreset {
  one_mile
  two_mile
  three_mile
  two_k
  five_k
}

enum TreeState {
  wilted
  recovering
  sprout
  growing
  thriving
  full_vitality
}

// ─── User ──────────────────────────────────────────────────────────────────
// Mirrors Supabase auth.users via shared UUID. JWT.sub === User.id.
// Profile fields nullable so we can upsert from JWT before onboarding completes.

model User {
  id          String   @id @db.Uuid
  email       String?  @unique
  username    String?  @unique
  displayName String?
  avatarUrl   String?

  // Profile
  goals           String[] @default([])      // ["strength", "conditioning"]
  experienceLevel String?                    // "beginner" | "intermediate" | "advanced"
  trainingDays    Int[]    @default([1, 2, 3, 4, 5]) // weekday ints, 0=Sun
  equipment       String[] @default([])
  injuries        String[] @default([])
  bodyWeight      Float?                     // always kg
  treeType        String   @default("oak")

  // Units & targets (Vitality Tree pillars)
  unitSystem        UnitSystem @default(metric)
  stepsGoal         Int        @default(8000)
  proteinTargetG    Int        @default(150)
  waterTargetMl     Int        @default(2500)
  restTimerDefaultS Int        @default(120)

  // Onboarding
  onboardingComplete Boolean @default(false)
  onboardingStep     String?

  // Legal
  privacyAcceptedAt DateTime?
  termsAcceptedAt   DateTime?
  aiTrainingOptOut  Boolean   @default(false)

  // Soft delete pipeline (App Store hard requirement)
  deletedAt     DateTime?
  deletionDueAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vitalityState VitalityState?
  userMemory    UserMemory?
  workouts      WorkoutLog[]
  dailyScores   DailyScore[]
  prs           PRRecord[]
  nutritionLogs SimpleNutritionLog[]
  userBadges    UserBadge[]

  @@map("users")
}

// ─── VitalityState ─────────────────────────────────────────────────────────
// 1:1 with User. Holds streak/freeze/timezone state — all mutable per-user
// but rarely changes. Streak math uses this row's timezone.

model VitalityState {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @unique @db.Uuid
  streak         Int       @default(0)
  longestStreak  Int       @default(0)
  treeHealth     Float     @default(100) // 0-100
  treeStage      TreeState @default(sprout)
  lastActiveDate DateTime?
  freezeTokens   Int       @default(0)
  timezone       String    @default("UTC")
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vitality_states")
}

// ─── WorkoutLog ────────────────────────────────────────────────────────────
// One row per session (strength workout OR run). Run fields populated only
// for WorkoutType.run. sessionRpe/notes are V1.5 fields, nullable in V1.

model WorkoutLog {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  name String
  type WorkoutType

  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  isFreezeDay Boolean   @default(false)

  // V1.5 — schema ships in V1, populated post-launch
  sessionRpe Int?
  notes      String?

  // Run-specific fields (only populated when type = run)
  runDistanceM      Int?
  runDurationS      Int?
  runPaceSPerKm     Int?
  runType           RunType?
  runDistancePreset RunDistancePreset?
  runRoutePolyline  String?
  runSplitPaces     Json?

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets WorkoutSet[]
  prs  PRRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startedAt])
  @@index([userId, type])
  @@map("workout_logs")
}

// ─── WorkoutSet ────────────────────────────────────────────────────────────

model WorkoutSet {
  id           String @id @default(uuid()) @db.Uuid
  workoutLogId String @db.Uuid

  exerciseName String
  exerciseId   String?

  setNumber Int
  reps      Int
  weightKg  Float?
  rpe       Int?
  notes     String?

  completedAt DateTime @default(now())

  workout WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)

  @@index([workoutLogId, setNumber])
  @@map("workout_sets")
}

// ─── DailyScore ────────────────────────────────────────────────────────────
// One row per user per day. Drives Vitality Tree state.
// Score formula: steps*0.40 + protein*0.30 + water*0.30 (each capped at 1.0).
// Rest days: stepsScore = 0.5 (neutral) — tree never penalises recovery.

model DailyScore {
  id     String   @id @default(uuid()) @db.Uuid
  userId String   @db.Uuid
  date   DateTime @db.Date

  stepsCount Int   @default(0)
  stepsGoal  Int
  stepsScore Float @default(0)

  proteinG       Int   @default(0)
  proteinTargetG Int
  proteinScore   Float @default(0)

  waterMl       Int   @default(0)
  waterTargetMl Int
  waterScore    Float @default(0)

  totalScore Float     @default(0)
  isRestDay  Boolean   @default(false)
  isFreezeDay Boolean  @default(false)
  treeState  TreeState @default(sprout)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_scores")
}

// ─── SimpleNutritionLog ────────────────────────────────────────────────────
// Granular nutrition log — keeps protein+water separate from DailyScore so
// future smart-fuel features can extend without migrations to DailyScore.

model SimpleNutritionLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  date      DateTime @db.Date
  proteinG  Int      @default(0)
  waterMl   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("simple_nutrition_logs")
}

// ─── PRRecord ──────────────────────────────────────────────────────────────

model PRRecord {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  exerciseName String
  value        Float
  unit         String

  workoutLogId String?  @db.Uuid
  achievedAt   DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout WorkoutLog? @relation(fields: [workoutLogId], references: [id], onDelete: SetNull)

  @@index([userId, exerciseName, achievedAt])
  @@map("pr_records")
}

// ─── UserMemory ────────────────────────────────────────────────────────────
// V1.5 readiness — schema ships in V1 empty. All fields nullable.
// Populated by BullMQ jobs (memoryUpdate, sentimentExtraction, behavioralAnalytics).
// Spec source: docs/waliFit_Technical_Architecture.md §3 + §14.2

model UserMemory {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  // Coaching memory (§3)
  coachingSummary    String?
  keyInsights        Json    @default("[]") // string[]
  communicationStyle String? // "direct" | "encouraging" | "analytical"
  recurringStruggles Json    @default("[]") // string[]
  breakthroughs      Json    @default("[]") // string[]
  sessionRpeHistory  Json    @default("[]") // {date, workout, rpe}[]
  journalInsights    Json    @default("[]")

  // Behavioral analytics (§14.2)
  trainingAdherence    Float?
  avgSessionRpe        Float?
  rpeTrend             String? // "rising" | "stable" | "falling"
  volumeTrend          String? // "increasing" | "stable" | "decreasing"
  prVelocity           String? // "fast" | "plateaued" | "regressing"
  nutritionConsistency Float?
  hydrationConsistency Float?
  preferredSessionMins Int?
  peakTrainingDays     Json    @default("[]")
  fatigueSignals       Json    @default("[]")
  injuryHistory        Json    @default("[]")

  // Sentiment (§14.2)
  sentimentTrend  String? // "positive" | "neutral" | "struggling" | "frustrated"
  motivationScore Int?
  sleepSignals    Json    @default("[]")

  // Personality (§14.2)
  personalityType     String? // "data-driven"|"encouragement"|"competitive"|"autonomous"
  responseToVolume    String? // "thrives" | "struggles"
  responseToIntensity String? // "thrives" | "struggles"

  // Engagement
  totalConversations Int       @default(0)
  lastConversationAt DateTime?
  lastActiveAt       DateTime?
  aiEngagementLevel  String? // "high" | "medium" | "low"

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_memories")
}

// ─── Badge + UserBadge ─────────────────────────────────────────────────────
// V1: schema + 8 seeded rows. Trigger hooks land in item 4.
// Spec source: docs/waliFit_Technical_Architecture.md §15.

model Badge {
  id           String    @id @default(uuid()) @db.Uuid
  key          String    @unique
  name         String
  tier         String // "iron" | "bronze" | "silver" | "gold"
  scope        String    @default("personal") // "personal" | "squad"
  opensAt      DateTime?
  closesAt     DateTime?
  squadId      String?
  isRelational Boolean   @default(false)

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  badgeId   String   @db.Uuid
  awardedAt DateTime
  squadId   String?
  isPinned  Boolean  @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}
