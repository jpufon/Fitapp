// waliFit backend — Prisma schema
// Aligns with Supabase auth.users via User.id (UUID matches Supabase user UUID).
// V1 core models: User, VitalityState, WorkoutLog, WorkoutSet, DailyScore,
// SimpleNutritionLog, PRRecord, UserMemory (empty), Badge, UserBadge.
// Run data lives on WorkoutLog (no separate model — per V1 features doc §F12).
// Spec source of truth: docs/waliFit_Technical_Architecture.md §3, §14.2, §15.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum UnitSystem {
  metric
  imperial
}

enum WorkoutType {
  strength
  hybrid
  conditioning
  run
  rest
}

enum RunType {
  free
  preset
}

enum RunDistancePreset {
  one_mile
  two_mile
  three_mile
  two_k
  five_k
}

enum TreeState {
  wilted
  recovering
  sprout
  growing
  thriving
  full_vitality
}

// ─── User ──────────────────────────────────────────────────────────────────
// Mirrors Supabase auth.users via shared UUID. JWT.sub === User.id.
// Profile fields nullable so we can upsert from JWT before onboarding completes.

model User {
  id          String   @id @db.Uuid
  email       String?  @unique
  username    String?  @unique
  displayName String?
  avatarUrl   String?

  // Profile
  goals           String[] @default([])      // ["strength", "conditioning"]
  experienceLevel String?                    // "beginner" | "intermediate" | "advanced"
  trainingDays    Int[]    @default([1, 2, 3, 4, 5]) // weekday ints, 0=Sun
  equipment       String[] @default([])
  injuries        String[] @default([])
  bodyWeight      Float?                     // always kg
  treeType        String   @default("oak")

  // Units & targets (Vitality Tree pillars)
  unitSystem        UnitSystem @default(metric)
  stepsGoal         Int        @default(8000)
  proteinTargetG    Int        @default(150)
  waterTargetMl     Int        @default(2500)
  restTimerDefaultS Int        @default(120)

  // Onboarding
  onboardingComplete Boolean @default(false)
  onboardingStep     String?

  // Legal
  privacyAcceptedAt DateTime?
  termsAcceptedAt   DateTime?
  aiTrainingOptOut  Boolean   @default(false)

  // Soft delete pipeline (App Store hard requirement)
  deletedAt     DateTime?
  deletionDueAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vitalityState     VitalityState?
  userMemory        UserMemory?
  workouts          WorkoutLog[]
  dailyScores       DailyScore[]
  prs               PRRecord[]
  nutritionLogs     SimpleNutritionLog[]
  nutritionEntries  NutritionEntry[]
  userBadges        UserBadge[]
  squadsOwned       Squad[]              @relation("SquadOwner")
  squadMemberships  SquadMember[]
  feedItems         FeedItem[]
  feedReactions     FeedReaction[]

  @@map("users")
}

// ─── VitalityState ─────────────────────────────────────────────────────────
// 1:1 with User. Holds streak/freeze/timezone state — all mutable per-user
// but rarely changes. Streak math uses this row's timezone.

model VitalityState {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   String    @unique @db.Uuid
  streak                   Int       @default(0)
  longestStreak            Int       @default(0)
  treeHealth               Float     @default(100) // 0-100
  treeStage                TreeState @default(sprout)
  lastActiveDate           DateTime?
  freezeTokens             Int       @default(0)
  // Highest streak threshold (7/30/60/100) we've already awarded a token for.
  // Resets to 0 when the streak breaks so milestones are re-earnable.
  lastFreezeAwardedStreak  Int       @default(0)
  timezone                 String    @default("UTC")
  updatedAt                DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vitality_states")
}

// ─── WorkoutLog ────────────────────────────────────────────────────────────
// One row per session (strength workout OR run). Run fields populated only
// for WorkoutType.run. sessionRpe/notes are V1.5 fields, nullable in V1.

model WorkoutLog {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  name String
  type WorkoutType

  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  isFreezeDay Boolean   @default(false)

  // V1.5 — schema ships in V1, populated post-launch
  sessionRpe Int?
  notes      String?

  // Run-specific fields (only populated when type = run)
  runDistanceM      Int?
  runDurationS      Int?
  runPaceSPerKm     Int?
  runType           RunType?
  runDistancePreset RunDistancePreset?
  runRoutePolyline  String?
  runSplitPaces     Json?

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets WorkoutSet[]
  prs  PRRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startedAt])
  @@index([userId, type])
  @@map("workout_logs")
}

// ─── WorkoutSet ────────────────────────────────────────────────────────────

model WorkoutSet {
  id           String @id @default(uuid()) @db.Uuid
  workoutLogId String @db.Uuid

  // Mobile-minted UUID per set tap. Unique per workout so retries from the
  // offline sync queue collapse into a single insert.
  clientId String @db.Uuid

  exerciseName String
  exerciseId   String?

  setNumber Int
  reps      Int
  weightKg  Float?
  rpe       Int?
  notes     String?

  // Conditioning fields (only populated when set logs a timed/rounds segment).
  // Strength sets keep these null; one row = one unit of work regardless of mode.
  durationS       Int?    // total time of the segment (timed work, AMRAP)
  roundNumber     Int?    // 1-based round index for rounds-based sessions
  intervalWorkS   Int?    // work interval (e.g. 30s on)
  intervalRestS   Int?    // rest interval (e.g. 30s off)

  completedAt DateTime @default(now())

  workout WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)

  @@unique([workoutLogId, clientId])
  @@index([workoutLogId, setNumber])
  @@map("workout_sets")
}

// ─── DailyScore ────────────────────────────────────────────────────────────
// One row per user per day. Drives Vitality Tree state.
// Score formula: steps*0.40 + protein*0.30 + water*0.30 (each capped at 1.0).
// Rest days: stepsScore = 0.5 (neutral) — tree never penalises recovery.

model DailyScore {
  id     String   @id @default(uuid()) @db.Uuid
  userId String   @db.Uuid
  date   DateTime @db.Date

  stepsCount Int   @default(0)
  stepsGoal  Int
  stepsScore Float @default(0)

  proteinG       Int   @default(0)
  proteinTargetG Int
  proteinScore   Float @default(0)

  waterMl       Int   @default(0)
  waterTargetMl Int
  waterScore    Float @default(0)

  totalScore Float     @default(0)
  isRestDay  Boolean   @default(false)
  isFreezeDay Boolean  @default(false)
  treeState  TreeState @default(sprout)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_scores")
}

// ─── SimpleNutritionLog ────────────────────────────────────────────────────
// Granular nutrition log — keeps protein+water separate from DailyScore so
// future smart-fuel features can extend without migrations to DailyScore.

model SimpleNutritionLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  date      DateTime @db.Date
  proteinG  Int      @default(0)
  waterMl   Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("simple_nutrition_logs")
}

// ─── NutritionEntry ────────────────────────────────────────────────────────
// Append-only ledger of every protein/water tap. SimpleNutritionLog is the
// SUM materialization; this is the source of truth.
// `clientId` is the mobile-minted UUID per tap. Unique per user so retries
// from the offline sync queue collapse into a single insert.

model NutritionEntry {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  date          DateTime @db.Date
  clientId      String
  proteinDeltaG Int      @default(0)
  waterDeltaMl  Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId, date])
  @@map("nutrition_entries")
}

// ─── PRRecord ──────────────────────────────────────────────────────────────

model PRRecord {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  exerciseName String
  value        Float
  unit         String

  workoutLogId String?  @db.Uuid
  achievedAt   DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout WorkoutLog? @relation(fields: [workoutLogId], references: [id], onDelete: SetNull)

  @@index([userId, exerciseName, achievedAt])
  @@map("pr_records")
}

// ─── UserMemory ────────────────────────────────────────────────────────────
// V1.5 readiness — schema ships in V1 empty. All fields nullable.
// Populated by BullMQ jobs (memoryUpdate, sentimentExtraction, behavioralAnalytics).
// Spec source: docs/waliFit_Technical_Architecture.md §3 + §14.2

model UserMemory {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  // Coaching memory (§3)
  coachingSummary    String?
  keyInsights        Json    @default("[]") // string[]
  communicationStyle String? // "direct" | "encouraging" | "analytical"
  recurringStruggles Json    @default("[]") // string[]
  breakthroughs      Json    @default("[]") // string[]
  sessionRpeHistory  Json    @default("[]") // {date, workout, rpe}[]
  journalInsights    Json    @default("[]")

  // Behavioral analytics (§14.2)
  trainingAdherence    Float?
  avgSessionRpe        Float?
  rpeTrend             String? // "rising" | "stable" | "falling"
  volumeTrend          String? // "increasing" | "stable" | "decreasing"
  prVelocity           String? // "fast" | "plateaued" | "regressing"
  nutritionConsistency Float?
  hydrationConsistency Float?
  preferredSessionMins Int?
  peakTrainingDays     Json    @default("[]")
  fatigueSignals       Json    @default("[]")
  injuryHistory        Json    @default("[]")

  // Sentiment (§14.2)
  sentimentTrend  String? // "positive" | "neutral" | "struggling" | "frustrated"
  motivationScore Int?
  sleepSignals    Json    @default("[]")

  // Personality (§14.2)
  personalityType     String? // "data-driven"|"encouragement"|"competitive"|"autonomous"
  responseToVolume    String? // "thrives" | "struggles"
  responseToIntensity String? // "thrives" | "struggles"

  // Engagement
  totalConversations Int       @default(0)
  lastConversationAt DateTime?
  lastActiveAt       DateTime?
  aiEngagementLevel  String? // "high" | "medium" | "low"

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_memories")
}

// ─── Badge + UserBadge ─────────────────────────────────────────────────────
// V1: schema + 8 seeded rows. Trigger hooks land in item 4.
// Spec source: docs/waliFit_Technical_Architecture.md §15.

model Badge {
  id           String    @id @default(uuid()) @db.Uuid
  key          String    @unique
  name         String
  tier         String // "iron" | "bronze" | "silver" | "gold"
  scope        String    @default("personal") // "personal" | "squad"
  opensAt      DateTime?
  closesAt     DateTime?
  squadId      String?
  isRelational Boolean   @default(false)

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  badgeId   String   @db.Uuid
  awardedAt DateTime
  squadId   String?
  isPinned  Boolean  @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ─── WorkoutTemplate ───────────────────────────────────────────────────────
// User-saved reusable session structure. Concrete sessions still log against
// WorkoutLog at runtime; templates are pre-fill state, never history.

model WorkoutTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  name        String
  description String?
  type        WorkoutType @default(strength)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exercises WorkoutTemplateExercise[]

  @@index([userId, archived])
  @@map("workout_templates")
}

model WorkoutTemplateExercise {
  id         String @id @default(uuid()) @db.Uuid
  templateId String @db.Uuid

  exerciseName String
  exerciseId   String?

  position    Int     // 0-based ordering within the template
  defaultSets Int     @default(3)
  defaultReps Int?    // null for time-based or rounds-based segments
  restS       Int?    // recommended rest between sets (seconds)

  // Conditioning preset values. UI flips between strength rows / interval rows
  // / rounds rows based on which of these are set.
  durationS     Int?  // timed segment duration
  rounds        Int?  // total rounds for rounds-based
  intervalWorkS Int?
  intervalRestS Int?

  notes String?

  template WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, position])
  @@map("workout_template_exercises")
}

// ─── Exercise ──────────────────────────────────────────────────────────────
// Reference library — read-only catalogue seeded from wger API.
// One source of truth for the exercise library across V1 + Sprint 4 RAG.
// Embedding column added in Sprint 4 once pgvector extension is enabled.

model Exercise {
  id              String   @id @default(uuid()) @db.Uuid
  wgerId          Int?     @unique
  name            String
  category        String   // "strength" | "conditioning" | "mobility" | "cardio"
  primaryMuscles  String[] @default([])
  secondaryMuscles String[] @default([])
  equipment       String[] @default([])
  instructions    String?
  movementType    String?  // "compound" | "isolation" | "olympic" | "bodyweight"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([name])
  @@index([updatedAt])
  @@map("exercises")
}

// ─── Arena (V1.x scaffold) ─────────────────────────────────────────────────
// Squad = small group (≤30) competing on a shared leaderboard. FeedItem =
// activity event surfaced in The Arena. Reactions are one-per-user-per-type.
// Owner-only delete; members can leave any time. Invite by code.

model Squad {
  id                String   @id @default(uuid()) @db.Uuid
  name              String
  squadType         String   @default("hybrid") // "hybrid" | "run_club"
  runFocusDistance  String?                     // "1mi" | "2mi" | "3mi" | "2K" | "5K" | "all" (run_club only)
  maxMembers        Int      @default(30)
  ownerId           String   @db.Uuid
  inviteCode        String   @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  owner     User          @relation("SquadOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members   SquadMember[]
  feedItems FeedItem[]

  @@map("squads")
}

model SquadMember {
  id       String   @id @default(uuid()) @db.Uuid
  squadId  String   @db.Uuid
  userId   String   @db.Uuid
  joinedAt DateTime @default(now())

  squad Squad @relation(fields: [squadId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([squadId, userId])
  @@index([userId])
  @@map("squad_members")
}

model FeedItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  squadId   String?  @db.Uuid

  // "strength_pr" | "run_pr" | "workout_complete" | "streak_milestone"
  eventType String
  exercise  String?
  value     String?
  delta     String?
  isRun     Boolean  @default(false)

  createdAt DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  squad     Squad?         @relation(fields: [squadId], references: [id], onDelete: SetNull)
  reactions FeedReaction[]

  @@index([squadId, createdAt])
  @@index([userId, createdAt])
  @@map("feed_items")
}

model FeedReaction {
  id         String   @id @default(uuid()) @db.Uuid
  feedItemId String   @db.Uuid
  userId     String   @db.Uuid
  type       String   @default("flame")
  createdAt  DateTime @default(now())

  feedItem FeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([feedItemId, userId, type])
  @@index([userId])
  @@map("feed_reactions")
}
