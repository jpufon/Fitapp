# waliFit mobile env — copy to .env (gitignored) and fill in values.
# Expo loads any EXPO_PUBLIC_* var from .env into process.env at build time.

# ─── Backend API ─────────────────────────────────────────────────────────────
# iOS Simulator / Android emulator / web — use localhost
# Real device on your LAN — use your dev machine's IP, e.g. http://10.0.0.166:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# ─── Supabase client ─────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# ─── Dev-only auth bypass ────────────────────────────────────────────────────
# Forged JWT for testing the API without a real sign-in. Generate via:
#   cd backend && npx tsx src/scripts/mint-dev-jwt.ts
# Pasted value is a Supabase-compatible authenticated JWT. Leave blank in prod.
EXPO_PUBLIC_DEV_JWT=
