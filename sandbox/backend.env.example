# Copy to backend.env (gitignored) and adjust Supabase + password to match credentials.env.
# Run API against sandbox DB:  cd backend && npm run dev:sandbox
#
# Security: use a staging Supabase project or dedicated dev keys — never production secrets.

NODE_ENV=development
PORT=4001
LOG_LEVEL=info

# Must match SANDBOX_DB_PASSWORD in sandbox/credentials.env (URL-encode special chars).
DATABASE_URL=postgresql://walifit:change-me-to-a-long-random-local-password@127.0.0.1:5433/walifit_sandbox?schema=public
DIRECT_URL=postgresql://walifit:change-me-to-a-long-random-local-password@127.0.0.1:5433/walifit_sandbox?schema=public

# Staging or dev Supabase only (same JWT secret as the project you mint dev JWTs against).
SUPABASE_URL=https://YOUR-STAGING-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Allow Expo web + Metro defaults (add ports if you use custom Metro).
CORS_ORIGINS=http://localhost:4001,http://localhost:8081,http://localhost:8086,http://localhost:19006

ANTHROPIC_API_KEY=
GOOGLE_GENAI_API_KEY=
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
